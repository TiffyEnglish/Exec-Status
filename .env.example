# EXEC_STATUS_MERGED=data/merged-2026-04-30.json
# Optional: YYYY-MM-DD anchor for calculated Jira target dates (default: date part of meta.generatedAt, else today)
EXEC_STATUS_REFERENCE_DATE=
# NexJ Health: Project EAF (Cached). Use this id in Atlassian MCP `getJiraIssue` / `searchJiraIssuesUsingJql` → `fields` arrays.
# REST-only: npm run jira:eaf resolves by field name via GET /rest/api/3/field when this is unset.
JIRA_EAF_FIELD_ID=customfield_10178
